{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Email Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "/tmp/email-preview", "-p", "4500", "--no-clipboard"],
      "port": 4500
    },
    {
      "name": "MedClinic Web (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "dev"],
      "port": 3100
    },
    {
      "name": "MedClinic API (Fastify)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "api", "dev"],
      "port": 3001
    }
  ]
}
