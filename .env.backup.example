# ============================================================
# MedClinic Pro — Variables del tooling de BACKUP / DRP
# Copiar a .env.backup.local para correr los scripts a mano.
# En CI estas variables viven como GitHub Actions Secrets.
# NINGÚN valor real va en este archivo.
# ============================================================

# --- Conexión a la BD (conexión DIRECTA, puerto 5432, NO pgbouncer) ---------
# pg_dump necesita conexión directa, no el pooler de transacciones.
# supabase.com/dashboard/project/gzojhcjymqtjswxqgkgk/settings/database
SUPABASE_DB_URL_DIRECT=postgresql://postgres.gzojhcjymqtjswxqgkgk:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# --- Cloudflare R2 (almacén offsite, S3-compatible) -------------------------
# Crear bucket dedicado con Versioning + Object Lock activados.
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET=medclinic-backups
R2_ENDPOINT=https://your-r2-account-id.r2.cloudflarestorage.com

# --- Cifrado (age) ----------------------------------------------------------
# SOLO la clave PÚBLICA va aquí / en CI. La privada NUNCA toca GitHub ni R2:
# vive offline (gestor de contraseñas + copia en USB/papel).
# Generar par:  age-keygen -o medclinic-backup.agekey   (guardar offline)
#               grep 'public key' muestra el recipient (empieza con age1...)
AGE_PUBLIC_KEY=age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Solo para restore/ensayo manual (apuntar al archivo de la clave privada):
# AGE_IDENTITY_FILE=/ruta/segura/medclinic-backup.agekey

# --- healthchecks.io (dead-man's switch) ------------------------------------
# Un check por job. Configurar cron + grace en cada uno (ver DRP.md).
HEALTHCHECKS_URL_DB_1200=https://hc-ping.com/your-uuid-db-1200
HEALTHCHECKS_URL_DB_1900=https://hc-ping.com/your-uuid-db-1900
HEALTHCHECKS_URL_CODE=https://hc-ping.com/your-uuid-code
HEALTHCHECKS_URL_VERIFY=https://hc-ping.com/your-uuid-verify

# --- Alertas por email (Resend) ---------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL=gerardo@b2d.mx

# --- Supabase Storage (respaldo de assets del bucket clinical-files) --------
SUPABASE_URL=https://gzojhcjymqtjswxqgkgk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
STORAGE_BUCKET=clinical-files

# --- Retención (opcional; valores por defecto en lib.sh) --------------------
# RETENTION_DAILY_DAYS=30
# RETENTION_WEEKLY_WEEKS=12
# RETENTION_MONTHLY_MONTHS=12

# --- WhatsApp (PENDIENTE — fase posterior, hoy no se usa) -------------------
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
