{
  "version": 2,
  "buildCommand": "prisma generate && tsc",
  "installCommand": "npm install -g pnpm@10.7.1 && pnpm install --no-frozen-lockfile",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "src/**,prisma/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ]
}
