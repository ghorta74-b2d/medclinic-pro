{
  "version": 2,
  "buildCommand": "prisma generate && pnpm typecheck",
  "installCommand": "npm install -g pnpm@10.7.1 && pnpm install --frozen-lockfile",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "src/**,prisma/**,generated/**,node_modules/.pnpm/**/*.so.node"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ]
}
