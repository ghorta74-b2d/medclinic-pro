# ============================================================
# MedClinic Pro — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Supabase (NEW instance — NOT shared with doctor-calendar) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Database (Supabase PostgreSQL via PgBouncer for serverless) ---
# Use Transaction mode (port 6543) for serverless/Prisma
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection for migrations (not pooled)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — crear en dashboard.stripe.com → Products
# 3 planes × 2 periodos (mensual y anual con −10%)
STRIPE_PRICE_ESENCIAL_MONTHLY=price_...
STRIPE_PRICE_ESENCIAL_ANNUAL=price_...
STRIPE_PRICE_PROFESIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESIONAL_ANNUAL=price_...
STRIPE_PRICE_CLINICA_MONTHLY=price_...
STRIPE_PRICE_CLINICA_ANNUAL=price_...

# URL base del frontend (para redirect tras checkout)
APP_BASE_URL=https://medclinic-web.vercel.app

# --- WhatsApp Business API (Meta) ---
WHATSAPP_API_VERSION=v19.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token

# --- ElevenLabs ---
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_AGENT_ID=your-agent-id
ELEVENLABS_WEBHOOK_SECRET=your-webhook-secret

# --- Daily.co (Telemedicine) ---
DAILY_API_KEY=your-daily-api-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
API_SECRET=a-random-long-secret-for-internal-calls

# --- PDF Generation ---
# Using @react-pdf/renderer — no external service needed

# --- Node ---
NODE_ENV=development
